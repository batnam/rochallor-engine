{
  "name": "@batnam/workflow-sdk",
  "version": "1.0.0",
  "description": "Node/TypeScript SDK for the JSON-only workflow engine (batnam)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "proto-gen": "protoc --plugin=protoc-gen-ts_proto=$(pwd)/node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src/generated --ts_proto_opt=env=node,outputServices=grpc-js,esModuleInterop=true -I ../proto ../proto/workflow/v1/engine.proto"
  },
  "dependencies": {
    "@confluentinc/kafka-javascript": "^1.9.0",
    "@grpc/grpc-js": "^1.12.6",
    "@grpc/proto-loader": "^0.7.13",
    "prom-client": "^15.1.3",
    "undici": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "msw": "^2.7.3",
    "ts-proto": "^2.6.1",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "files": [
    "dist/**/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
