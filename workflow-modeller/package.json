{
  "name": "workflow-modeller",
  "version": "0.0.0",
  "private": true,
  "description": "Visual workflow modeller for the Rochallor Workflow Engine — feature 001-workflow-modeller.",
  "type": "module",
  "engines": {
    "node": ">=20.10"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "prebuild": "npm run build:parser --silent",
    "predev": "npm run build:parser --silent",
    "build:parser": "peggy --format es -o src/domain/expression/parser.generated.ts src/domain/expression/grammar.pegjs && node scripts/post-parser.mjs",
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:drift": "vitest run tests/drift.test.ts",
    "size": "tsx scripts/bundle-size.ts"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.5",
    "dagre": "^0.8.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8",
    "zundo": "^2.2.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.47.2",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/dagre": "^0.7.52",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^25.0.1",
    "msw": "^2.6.0",
    "peggy": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
